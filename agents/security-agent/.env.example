# Database credentials
DB_USERNAME=admin
DB_PASSWORD=your_password_here

# Ollama base URL (optional, defaults to http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# MaxMind GeoLite2 automatic download key (used by geoip_lookup)
MAXMIND_LICENSE_KEY=your_maxmind_license_key_here
# Optional overrides:
# MAXMIND_EDITION_ID=GeoLite2-City
# MAXMIND_DB_PATH=data/geoip/GeoLite2-City.mmdb

